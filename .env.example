# agi — environment template. Copy to .env (gitignored) and fill in real values.
# Do NOT commit .env. Never paste real secrets into .env.example.

# ---- agi runtime (Fusion-consumed) ----
FUSION_DASHBOARD_TOKEN=          # openssl rand -hex 24
FUSION_DAEMON_TOKEN=             # openssl rand -hex 24
FUSION_API_KEY=                  # openssl rand -hex 24
FUSION_BEARER_TOKEN=

# ---- AI provider (OpenAI-compatible) ----
AI_BASE_URL=https://api.example.com/v1
AI_MODEL=your-model
AI_API_KEY=

# ---- GitHub App integration (Fusion-consumed) ----
FUSION_GITHUB_APP_ID=
FUSION_GITHUB_APP_CLIENT_ID=
FUSION_GITHUB_APP_CLIENT_SECRET=
FUSION_GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app-private-key.pem
FUSION_GITHUB_WEBHOOK_SECRET=

# ---- GitHub OAuth app (login) ----
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ---- GitHub PATs ----
GITHUB_TOKEN=
GITHUB_TOKEN_CLASSIC=

# ---- Analytics: PostHog ----
POSTHOG_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=

# ---- Monitoring: Sentry ----
SENTRY_AUTH_TOKEN=
SENTRY_ORG_TOKEN=
SENTRY_ORG=
SENTRY_DSN=

# ---- Auth: Better Auth / Google OAuth ----
BETTER_AUTH_API_KEY=
BETTER_AUTH_URL=https://your-app/api/auth
APP_URL=https://your-app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- external / rox project (not consumed by agi core) ----
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
NEON_API_KEY=
DATABASE_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
FUSION_BADGE_PUBSUB_REDIS_URL=
QSTASH_URL=
QSTASH_TOKEN=
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
RESEND_API_KEY=
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
LINEAR_API_KEY=
LINEAR_DEV_TOKEN=
RENDER_API_KEY=
